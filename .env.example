# DisasterResilienceHub Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_DB=disaster_resilience
POSTGRES_USER=drh_user
POSTGRES_PASSWORD=changeme_secure_password_minimum_16_chars

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_PASSWORD=changeme_redis_password_minimum_16_chars

# ============================================
# JWT AUTHENTICATION
# ============================================
# IMPORTANT: Must be at least 256 bits (32 characters) for HS256
JWT_SECRET=changeme_jwt_secret_key_minimum_256_bits_for_secure_signing_hs256_algorithm
JWT_EXPIRATION=3600000  # 1 hour in milliseconds
JWT_REFRESH_EXPIRATION=604800000  # 7 days in milliseconds

# ============================================
# LLM SERVICE CONFIGURATION
# ============================================
# Provider options: 'huggingface', 'xai', 'openai'
LLM_PROVIDER=huggingface
LLM_API_KEY=your_llm_api_key_here

# Hugging Face specific
HUGGINGFACE_MODEL=meta-llama/Llama-2-7b-chat-hf

# xAI specific (if using xAI)
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-1

# OpenAI specific (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# ============================================
# SPRING BOOT CONFIGURATION
# ============================================
# Options: 'dev', 'test', 'prod'
SPRING_PROFILE=prod

# ============================================
# LOGGING
# ============================================
# Options: 'DEBUG', 'INFO', 'WARN', 'ERROR'
LOG_LEVEL=INFO

# ============================================
# EXTERNAL API KEYS (Optional)
# ============================================
# NOAA API Key (for weather data)
NOAA_API_KEY=your_noaa_api_key_here

# USGS API Key (for seismic data)
USGS_API_KEY=your_usgs_api_key_here

# OpenStreetMap Nominatim (usually no key required)
OSM_API_URL=https://nominatim.openstreetmap.org

# ============================================
# SMS/EMAIL SERVICES (For MFA - Enterprise)
# ============================================
# Twilio (for SMS MFA)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (for email MFA and notifications)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@disasterresiliencehub.org

# ============================================
# SSO CONFIGURATION (Enterprise)
# ============================================
# SAML 2.0 (Okta example)
SAML_ENTITY_ID=https://your-okta-domain.okta.com
SAML_SSO_URL=https://your-okta-domain.okta.com/app/your-app/sso/saml
SAML_CERTIFICATE=your_base64_encoded_certificate

# OAuth2/OIDC (Azure AD example)
OAUTH2_CLIENT_ID=your_azure_client_id
OAUTH2_CLIENT_SECRET=your_azure_client_secret
OAUTH2_ISSUER_URI=https://login.microsoftonline.com/your-tenant-id/v2.0

# ============================================
# CORS CONFIGURATION
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ============================================
# MONITORING & OBSERVABILITY (Optional)
# ============================================
# Prometheus
PROMETHEUS_ENABLED=true

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# ============================================
# BACKUP CONFIGURATION (Optional)
# ============================================
# S3-compatible storage for backups
S3_BUCKET_NAME=drh-backups
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=us-east-1

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ============================================
# SESSION CONFIGURATION
# ============================================
SESSION_TIMEOUT_MINUTES=60
MAX_CONCURRENT_SESSIONS=5

# ============================================
# FILE UPLOAD LIMITS
# ============================================
MAX_FILE_SIZE_MB=50
MAX_REQUEST_SIZE_MB=100

# ============================================
# TIMEZONE
# ============================================
TZ=UTC

# ============================================
# APPLICATION URLs (Production)
# ============================================
FRONTEND_URL=https://yourdomain.com
API_GATEWAY_URL=https://api.yourdomain.com
WEBSOCKET_URL=wss://ws.yourdomain.com

# ============================================
# DEVELOPER OPTIONS (Development only)
# ============================================
# Set to 'true' to enable debugging features
DEBUG_MODE=false
ENABLE_SWAGGER=true
ENABLE_H2_CONSOLE=false
